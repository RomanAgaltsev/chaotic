{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "tag-separator": "/",
  "include-component-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    ".": {
      "include-component-in-tag": false
    },
    "adapter/aws": {
      "component": "adapter/aws"
    },
    "adapter/grpc": {
      "component": "adapter/grpc"
    },
    "adapter/io": {
      "component": "adapter/io"
    },
    "adapter/kafka": {
      "component": "adapter/kafka"
    },
    "adapter/mongo": {
      "component": "adapter/mongo"
    },
    "adapter/nats": {
      "component": "adapter/nats"
    },
    "adapter/net": {
      "component": "adapter/net"
    },
    "adapter/rabbitmq": {
      "component": "adapter/rabbitmq"
    },
    "adapter/redis": {
      "component": "adapter/redis"
    },
    "adapter/pgx": {
      "component": "adapter/pgx"
    },
    "cmd/chaotic-points": {
      "component": "cmd/chaotic-points"
    },
    "observer/otel": {
      "component": "observer/otel"
    },
    "observer/prometheus": {
      "component": "observer/prometheus"
    },
    "observer/slog": {
      "component": "observer/slog"
    },
    "source/file": {
      "component": "source/file"
    },
    "source/http": {
      "component": "source/http"
    }
  }
}
