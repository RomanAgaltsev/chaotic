{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "postUpdateOptions": ["gomodTidy"],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "description": "Group non-major Go module updates into one PR.",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go modules (non-major)"
    },
    {
      "description": "Group GitHub Actions updates.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Automerge non-major updates once CI passes.",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Automerge security updates regardless of bump type.",
      "matchUpdateTypes": ["major", "minor", "patch"],
      "isVulnerabilityAlert": true,
      "automerge": true
    }
  ]
}